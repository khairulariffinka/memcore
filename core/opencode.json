{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "memcore": {
      "description": "Memory intelligence layer for OpenCode — memory, reminders, work, improve, compress",
      "mode": "primary",
      "permission": {
        "edit": "allow",
        "bash": "ask",
        "glob": "allow",
        "grep": "allow",
        "read": "allow",
        "skill": "allow"
      }
    },
    "memcore-plan": {
      "description": "Read-only planning agent for MemCore — analysis, exploration, and task breakdown without modifications",
      "mode": "plan",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "glob": "allow",
        "grep": "allow",
        "read": "allow",
        "skill": "allow"
      }
    }
  },
  "skill": {
    "improve": {
      "permission": "ask"
    }
  }
}
